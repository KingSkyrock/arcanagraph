PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/arcanagraph
SESSION_COOKIE_NAME=arcanagraph_session
SESSION_EXPIRES_DAYS=5
FIREBASE_PROJECT_ID=arcanagraph-dev
# Leave this set only when you intentionally want the local Firebase Auth emulator.
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# Production options:
# 1. Set FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY
# 2. Or set FIREBASE_SERVICE_ACCOUNT_JSON
# 3. Or set FIREBASE_SERVICE_ACCOUNT_JSON_BASE64
# 4. Or point GOOGLE_APPLICATION_CREDENTIALS at a service account JSON file and also set FIREBASE_PROJECT_ID
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_APPLICATION_CREDENTIALS=
